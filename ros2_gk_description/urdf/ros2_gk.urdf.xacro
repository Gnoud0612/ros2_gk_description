<?xml version="1.0" ?>
<robot name="ros2_gk" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find ros2_gk_description)/urdf/materials.xacro" />
<xacro:include filename="$(find ros2_gk_description)/urdf/ros2_gk.trans" />
<xacro:include filename="$(find ros2_gk_description)/urdf/ros2_gk.gazebo" />

<link name="base_footprint"/>

<joint name="base_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <mass value="5.0"/>
    <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  </link>

<link name="right_wheel_link_1">
  <inertial>
    <origin xyz="-0.0 0.15 -0.1" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 0.15 -0.1" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/right_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="1.570796 0 0"/>
    <geometry>
      <cylinder radius="0.1" length="0.04"/>
    </geometry>
  </collision>
</link>

<link name="left_wheel_link_1">
  <inertial>
    <origin xyz="0.0 -0.15 -0.1" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.0 -0.15 -0.1" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/left_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="1.570796 0 0"/>
    <geometry>
      <cylinder radius="0.1" length="0.04"/>
    </geometry>
  </collision>
</link>

<link name="arm_1_link_1">
  <inertial>
    <origin xyz="-0.15 -0.0 -0.45" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.15 -0.0 -0.45" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/arm_1_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<link name="arm_2_link_1">
  <inertial>
    <origin xyz="-0.364996 0.001273 -0.43" rpy="0 0 0"/>
    <mass value="0.3"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.364996 0.001273 -0.43" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/arm_2_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<link name="camera_link_1">
  <inertial>
    <origin xyz="-0.5 -0.0 -0.1" rpy="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.5 -0.0 -0.1" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/camera_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<link name="lidar_link_1">
  <inertial>
    <origin xyz="-0.465 -0 -0.2" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.465 -0 -0.2" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<link name="gps_link_1">
  <inertial>
    <origin xyz="-0.25 -0.0 -0.2" rpy="0 0 0"/>
    <mass value="0.02"/>
    <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.25 -0.0 -0.2" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/gps_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
</link>

<link name="caster_wheel_link_1">
  <inertial>
    <origin xyz="-0.4 -0 -0.05" rpy="0 0 0"/>
    <mass value="0.2"/>
    <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.4 -0 -0.05" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://ros2_gk_description/meshes/caster_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.05"/>
    </geometry>
  </collision>
</link>

<joint name="right_wheel_joint" type="continuous">
  <origin xyz="0.0 -0.15 0.1" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_wheel_link_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <dynamics damping="0.2" friction="0.2"/>
</joint>

<joint name="left_wheel_joint" type="continuous">
  <origin xyz="0.0 0.15 0.1" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_wheel_link_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <dynamics damping="0.2" friction="0.2"/>
</joint>

<joint name="arm_1_joint" type="revolute">
  <origin xyz="0.15 0.0 0.45" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="arm_1_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
  <dynamics damping="0.5" friction="0.5"/>
</joint>

<joint name="arm_2_joint" type="revolute">
  <origin xyz="0.214996 -0.001273 -0.02" rpy="0 0 0"/>
  <parent link="arm_1_link_1"/>
  <child link="arm_2_link_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0" lower="-2.416195" effort="100" velocity="100"/>
  <dynamics damping="0.5" friction="0.5"/>
</joint>

<joint name="camera_joint" type="fixed">
  <origin xyz="0.5 0.0 0.1" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="camera_link_1"/>
</joint>

<joint name="lidar_joint" type="fixed">
  <origin xyz="0.465 0 0.2" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lidar_link_1"/>
</joint>

<joint name="gps_joint" type="fixed">
  <origin xyz="0.25 0.0 0.2" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="gps_link_1"/>
</joint>

<joint name="caster_wheel_joint" type="fixed">
  <origin xyz="0.4 0 0.05" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="caster_wheel_link_1"/>
</joint>

<gazebo reference="lidar_joint">
  <preserveFixedJoint>true</preserveFixedJoint>
</gazebo>
<gazebo reference="camera_joint">
  <preserveFixedJoint>true</preserveFixedJoint>
</gazebo>
<gazebo reference="gps_joint">
  <preserveFixedJoint>true</preserveFixedJoint>
</gazebo>
<gazebo reference="caster_wheel_joint">
  <preserveFixedJoint>true</preserveFixedJoint>
</gazebo>

<gazebo reference="right_wheel_link_1">
  <mu1>200.0</mu1>
  <mu2>100.0</mu2>
  <kp>10000000.0</kp>
  <kd>1.0</kd>
</gazebo>

<gazebo reference="left_wheel_link_1">
  <mu1>200.0</mu1>
  <mu2>100.0</mu2>
  <kp>10000000.0</kp>
  <kd>1.0</kd>
</gazebo>

<gazebo reference="caster_wheel_link_1">
  <mu1>0.0</mu1>
  <mu2>0.0</mu2>
  <kp>10000000.0</kp>
  <kd>1.0</kd>
</gazebo>

<gazebo>
  <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
    <update_rate>50</update_rate>
    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>
    <wheel_separation>0.34</wheel_separation>
    <wheel_diameter>0.2</wheel_diameter>
    <max_wheel_torque>20</max_wheel_torque>
    <max_wheel_acceleration>1.0</max_wheel_acceleration>
    <command_topic>cmd_vel</command_topic>
    <odometry_topic>odom</odometry_topic>
    <odometry_frame>odom</odometry_frame>
    <robot_base_frame>base_footprint</robot_base_frame>
    <publish_odom>true</publish_odom>
    <publish_odom_tf>true</publish_odom_tf>
    <publish_wheel_tf>true</publish_wheel_tf>
  </plugin>
</gazebo>

<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>
  <joint name="arm_1_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
  </joint>
  <joint name="arm_2_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
  </joint>
</ros2_control>

<gazebo>
  <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
    <parameters>$(find ros2_gk_description)/config/arm_controllers.yaml</parameters>
  </plugin>
</gazebo>

<gazebo reference="lidar_link_1">
  <sensor name="lidar" type="ray">
    <always_on>true</always_on>
    <visualize>true</visualize> <update_rate>10</update_rate> <ray>
      <scan>
        <horizontal>
          <samples>360</samples> <resolution>1.0</resolution>
          <min_angle>-3.14159</min_angle> <max_angle>3.14159</max_angle>  </horizontal>
      </scan>
      <range>
        <min>0.15</min> <max>10.0</max> <resolution>0.015</resolution>
      </range>
    </ray>
    <plugin name="scan" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <remapping>~/out:=scan</remapping> </ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>lidar_link_1</frame_name>
    </plugin>
  </sensor>
</gazebo>

<gazebo reference="camera_link_1">
  <sensor name="camera" type="camera">
    <always_on>true</always_on>
    <visualize>true</visualize> <update_rate>30</update_rate> <camera>
      <horizontal_fov>1.089</horizontal_fov> <image>
        <format>R8G8B8</format> <width>640</width>      <height>480</height>    </image>
      <clip>
        <near>0.05</near>
        <far>8.0</far>
      </clip>
    </camera>
    <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
      <frame_name>camera_link_1</frame_name>
    </plugin>
  </sensor>
</gazebo>

<gazebo reference="gps_link_1">
  <sensor name="gps_sensor" type="gps">
    <always_on>true</always_on>
    <update_rate>1.0</update_rate> <plugin name="gps_controller" filename="libgazebo_ros_gps_sensor.so">
      <ros>
        <remapping>~/out:=gps/fix</remapping> </ros>
      <frame_name>gps_link_1</frame_name>
    </plugin>
  </sensor>
</gazebo>

</robot>
