<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">
    <include>
      <uri>model://sun</uri>
    </include>
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <model name='wall_north'>
      <pose>0 4 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>8.2 0.2 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>8.2 0.2 1</size></box></geometry><material><script><name>Gazebo/Grey</name></script></material></visual>
      </link>
    </model>
    <model name='wall_south'>
      <pose>0 -4 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>8.2 0.2 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>8.2 0.2 1</size></box></geometry><material><script><name>Gazebo/Grey</name></script></material></visual>
      </link>
    </model>
    <model name='wall_east'>
      <pose>4 0 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>0.2 8 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>0.2 8 1</size></box></geometry><material><script><name>Gazebo/Grey</name></script></material></visual>
      </link>
    </model>
    <model name='wall_west'>
      <pose>-4 0 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>0.2 8 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>0.2 8 1</size></box></geometry><material><script><name>Gazebo/Grey</name></script></material></visual>
      </link>
    </model>

    <model name='red_box'>
      <pose>2 2 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>1 1 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>1 1 1</size></box></geometry><material><script><name>Gazebo/Red</name></script></material></visual>
      </link>
    </model>

    <model name='blue_cylinder'>
      <pose>-2.5 2.5 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry></collision>
        <visual name='visual'><geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry><material><script><name>Gazebo/Blue</name></script></material></visual>
      </link>
    </model>

    <model name='green_sphere'>
      <pose>2.5 -2.5 0.5 0 0 0</pose>
      <static>1</static> <link name='link'>
        <collision name='collision'><geometry><sphere><radius>0.5</radius></sphere></geometry></collision>
        <visual name='visual'><geometry><sphere><radius>0.5</radius></sphere></geometry><material><script><name>Gazebo/Green</name></script></material></visual>
      </link>
    </model>

    <model name='yellow_panel'>
      <pose>-2 -2 0.5 0 0 0</pose>
      <static>1</static>
      <link name='link'>
        <collision name='collision'><geometry><box><size>0.2 2 1</size></box></geometry></collision>
        <visual name='visual'><geometry><box><size>0.2 2 1</size></box></geometry><material><script><name>Gazebo/Yellow</name></script></material></visual>
      </link>
    </model>

  </world>
</sdf>
